{
  "expo": {
    "name": "Discipl",
    "slug": "discipl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "discipl",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "studio.northbyte.discipl",
      "appleTeamId": "KJQ52F94YM",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.studio.northbyte.discipl"
        ]
      },
      "infoPlist": {
        "AppGroup": "group.studio.northbyte.discipl",
        "AppGroupIdentifier": "group.studio.northbyte.discipl"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "studio.northbyte.discipl"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-tracking-transparency",
      "expo-notifications",
      "@bacons/apple-targets",
      "react-native-appsflyer"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
